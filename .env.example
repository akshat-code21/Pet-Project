# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# Database (Supabase PostgreSQL asyncpg connection string)
# Format: postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# OpenAI (GPT-4o + text-embedding-3-small)
OPENAI_API_KEY=

# YouTube Data API v3 (optional — used for channel discovery; yt-dlp works without it)
YOUTUBE_API_KEY=

# Resend (email alerts for critical severity)
RESEND_API_KEY=

# Frontend URL (for CORS allow-list)
FRONTEND_URL=http://localhost:3000

# App configuration
APP_ENV=development
LOG_LEVEL=INFO
SCHEDULER_ENABLED=true
